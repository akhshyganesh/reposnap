{
  "name": "reposnap",
  "version": "1.1.0",
  "description": "A tool to create a codebase snapshot of the current directory, with options to include/exclude files or folders.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "reposnap": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node dist/tests/test.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "prepare": "husky install",
    "prepublishOnly": "npm run build",
    "publish:patch": "npm version patch && npm publish",
    "publish:minor": "npm version minor && npm publish",
    "publish:major": "npm version major && npm publish",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "changelog:first": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0"
  },
  "keywords": [
    "codebase",
    "snapshot",
    "npx",
    "utility"
  ],
  "author": "akhshyganesh",
  "license": "MIT",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akhshyganesh/reposnap.git"
  },
  "bugs": {
    "url": "https://github.com/akhshyganesh/reposnap/issues"
  },
  "homepage": "https://github.com/akhshyganesh/reposnap#readme",
  "dependencies": {
    "commander": "^10.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "husky": "^8.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "conventional-changelog-cli": "^3.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
